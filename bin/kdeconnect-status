#!/usr/bin/env bash
set -euo pipefail

status() {
    local available
    available=$(kdeconnect-cli -a --name-only 2>/dev/null)

    if [[ -z "$available" ]]; then
        echo '{"text":"󰌘","class":"disconnected","alt":"disconnected","tooltip":"KDE Connect: No devices"}'
    else
        local count names
        count=$(echo "$available" | grep -c .)
        names=$(echo "$available" | paste -sd, - | sed 's/,/, /g')
        jq -cn --arg count "$count" --arg names "$names" \
          '{text: ("󰌘 " + $count), class: "connected", alt: "connected", tooltip: ("KDE Connect: " + $names)}'
    fi
}

case "$1" in
    status) status ;;
    refresh) kdeconnect-cli --refresh ;;
    *) status ;;
esac
