# secrets
*.cred
*.env
*.pem
*.key
.ssh/
.gnupg/
.netrc
.git-credentials
.gitconfig.local
.aws/
.kube/
.config/gh/
.config/atuin/

# bin subdirs (vendor, private, etc.)
bin/*/

# shell history
.bash_history
.histfile
.zsh_history
.zhistory
.node_repl_history

# caches & generated
.zcompdump
.cache/
.local/
.mozilla/
.npm/
.cargo/

# only track whitelisted .config dirs
.config/*
!.config/bat/
!.config/btop/
!.config/fuzzel/
!.config/alacritty/
!.config/gitui/
!.config/gtk-3.0/
!.config/gtk-4.0/
!.config/hypr/
!.config/mise/
!.config/mpv/
!.config/nvim/
!.config/qt5ct/
!.config/qt6ct/
!.config/sheldon/
!.config/solaar/
!.config/starship.toml
!.config/swappy/
!.config/swaync/
!.config/tmux/
!.config/waybar/
!.config/zsh/

# solaar - only rules.yaml
.config/solaar/*
!.config/solaar/rules.yaml

# generated
.config/environment.d/paths.conf

# large files
*.zip

# dotfiles repo itself
.dotfiles/
