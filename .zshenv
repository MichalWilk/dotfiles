export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

export PATH="$HOME/.local/share/mise/shims:$HOME/bin:$HOME/bin/overrides:$HOME/bin/vendor:$HOME/bin/private:$HOME/.local/bin:$HOME/.local/share/JetBrains/Toolbox/bin:$HOME/.local/share/JetBrains/Toolbox/scripts:/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin"
export DOTNET_ROOT="$HOME/.local/share/mise/dotnet-root"

export CC=gcc
export CXX=g++

